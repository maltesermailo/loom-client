<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <!-- WifiLock.acquire() needs WAKE_LOCK; the FULL_LOW_LATENCY mode also reads
       WiFi state. See LoomActivity.kt for why the lock is not optional. -->
  <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
  <uses-permission android:name="android.permission.WAKE_LOCK" />

  <uses-feature android:name="android.hardware.vr.headtracking" android:required="true" />

  <application android:label="Loom" android:hasCode="true">
    <activity
        android:name=".LoomActivity"
        android:exported="true"
        android:launchMode="singleTask"
        android:screenOrientation="landscape"
        android:excludeFromRecents="false"
        android:configChanges="screenSize|screenLayout|orientation|keyboardHidden|keyboard|navigation|uiMode|density">

      <!-- Names the .so that android_main lives in; NativeActivity dlopen()s it. -->
      <meta-data android:name="android.app.lib_name" android:value="loom_quest" />

      <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
        <!-- Launches as an immersive VR app rather than a 2D panel. -->
        <category android:name="com.oculus.intent.category.VR" />
      </intent-filter>
    </activity>
  </application>

</manifest>
